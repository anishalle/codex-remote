{
  "name": "@t3tools/contracts",
  "version": "0.0.21",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    "./settings": {
      "types": "./src/settings.ts",
      "import": "./src/settings.ts",
      "require": "./src/settings.ts"
    },
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "tsdown src/index.ts --format esm,cjs --dts --watch --clean",
    "build": "tsdown src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "effect": "4.0.0-beta.45"
  },
  "devDependencies": {
    "@effect/language-service": "0.84.2",
    "@effect/vitest": "4.0.0-beta.45",
    "tsdown": "^0.20.3",
    "typescript": "^5.7.3",
    "vitest": "^4.0.0"
  }
}
