{
  "name": "codex-remote",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @codex-remote/web",
    "build:web": "npm run build --workspace @codex-remote/web",
    "typecheck:web": "npm run typecheck --workspace @codex-remote/web",
    "start:cloud-server": "node apps/cloud-server/src/index.ts",
    "start:mac-runner": "node apps/mac-runner-cli/src/index.ts",
    "start:cloud-runner": "node apps/cloud-runner/src/index.ts daemon",
    "test": "node --test apps/cloud-server/test/*.test.ts apps/mac-runner-cli/test/*.test.ts apps/cloud-runner/test/*.test.ts packages/workspace-packager/test/*.test.ts"
  },
  "engines": {
    "node": ">=25.0.0"
  }
}
