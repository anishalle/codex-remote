{
  "name": "codex-remote",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "effect": "4.0.0-beta.45",
      "@effect/atom-react": "4.0.0-beta.45",
      "@effect/openapi-generator": "4.0.0-beta.45",
      "@effect/platform-bun": "4.0.0-beta.45",
      "@effect/platform-node": "4.0.0-beta.45",
      "@effect/platform-node-shared": "4.0.0-beta.45",
      "@effect/sql-sqlite-bun": "4.0.0-beta.45",
      "@effect/vitest": "4.0.0-beta.45",
      "@effect/language-service": "0.84.2",
      "@types/bun": "^1.3.11",
      "@types/node": "^24.10.13",
      "tsdown": "^0.20.3",
      "typescript": "^5.7.3",
      "vitest": "^4.0.0"
    }
  },
  "scripts": {
    "dev:web": "bun run --cwd apps/web dev",
    "build:web": "bun run --cwd apps/web build",
    "typecheck:web": "bun run --cwd apps/web typecheck",
    "start:t3": "bun apps/server/src/bin.ts start",
    "serve:t3": "bun apps/server/src/bin.ts serve",
    "start:cloud-server": "node apps/cloud-server/src/index.ts",
    "start:mac-runner": "node apps/mac-runner-cli/src/index.ts",
    "start:cloud-runner": "node apps/cloud-runner/src/index.ts daemon",
    "test": "node --test apps/cloud-server/test/*.test.ts apps/mac-runner-cli/test/*.test.ts apps/cloud-runner/test/*.test.ts packages/workspace-packager/test/*.test.ts"
  },
  "overrides": {
    "@effect/atom-react": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/platform-node-shared": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@effect/vitest": "catalog:",
    "effect": "catalog:",
    "vite": "^8.0.0"
  },
  "engines": {
    "bun": "^1.3.11",
    "node": "^24.13.1"
  },
  "packageManager": "bun@1.3.11",
  "msw": {
    "workerDirectory": [
      "apps/web/public"
    ]
  },
  "trustedDependencies": [
    "node-pty"
  ]
}
